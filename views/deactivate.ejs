<style>
      body {
        margin: 0;
        padding: 0;
        background: linear-gradient(120deg, #005f73, #005f73);
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }

      .login-box {
        background-color: white;
        padding: 40px 30px;
        border-radius: 10px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        width: 100%;
        max-width: 400px;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
      }

      .login-box h2 {
        text-align: center;
        color: #023047;
        margin-bottom: 30px;
      }

      .login-box input[type="text"],
      .login-box input[type="password"] {
        width: 98%;
        padding: 12px 15px;
        margin: 10px 0;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: 16px;
      }

      .login-box button {
        width: 100%;
        padding: 12px;
        background-color: #005f73;
        color: white;
        font-size: 16px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: background-color 0.3s ease;
      }

      .login-box button:hover {
        background-color: #27899c;
      }

      .login-box p {
        text-align: center;
        font-size: 14px;
        color: #555;
        margin-top: 20px;
      }
      #directing {
        margin-top: 5px;
        color: rgb(203, 14, 14);
        display: none;
      }
    </style>
  </head>
  <body>
    <div class="login-box">
      <h2>Delete Account</h2>
      <form id="delete-form">
        
        <input
          type="password"
          name="password"
          id="pwd"
          placeholder="Enter your Password"
          required
        />
        <a style="float:right;margin-bottom: 10px;margin-right: 10px;color:#005f73;">Forgot password?</a>
        <button type="submit">Delete account</button>
        
      </form>
      <h3  id="userId" style="display:none;"><%=userId%></h3>
    </div>
    <script>
        document.getElementById("delete-form").addEventListener("submit",function(e)
    {
        e.preventDefault();
        let userId=document.getElementById("userId").innerText;
        let password=document.getElementById("pwd").value;
        let user={userId,password}
        deleteAccount(user)

    })
    function deleteAccount(user)
    {
        let xhr=new XMLHttpRequest();
        let url="/deactivate";
        xhr.open("POST",url);
        xhr.onload=()=>{
            let msg=xhr.responseText;
            console.log(msg)
            if(msg==="success")
        {
            localStorage.removeItem("isLogged");
            localStorage.removeItem("userId");
            window.location.replace("/logout")
        }
           else{
            alert("incorrect password")
           }
      
        }
        xhr.setRequestHeader("Content-Type","application/json");
        xhr.send(JSON.stringify(user))
    }
    </script>
    
