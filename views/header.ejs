<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Navbar with Toggle Buttons</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
        }

        header {
            background-color: #005f73;
            padding: 15px 30px;
        }

        .container-fluid {
            display: flex;
            justify-content: space-around;
            width: 100%;
        }

        .logo {
            font-weight: bold;
            font-size: 1.7rem;
            letter-spacing: 1px;
            color: white;
            white-space: nowrap;
        }

        #search-bar {
            width: 350px;
            margin-left: 300px;
            padding: 10px 15px;
            border: none;
            border-radius: 20px;
            outline: none;
            font-size: 15px;
            display: none;
            background-color: rgb(219, 235, 235);
        }

        .navbar-custom {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-left: auto;
        }

        .nav-link {
            color: white;
            text-decoration: none;
            font-size: 16px;
            font-weight: 500;
            padding: 8px 14px;
            border-radius: 6px;
            transition: all 0.3s ease;
            white-space: nowrap;
        }

        .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.15);
            color: white;
        }

        main {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            flex-direction: column;
        }

        @media (max-width: 1000px) {
            .container-fluid {
                flex-wrap: wrap;
                gap: 15px;
            }

            #search-bar {
                width: 100%;
                margin-left: 0;
                order: 3;
            }

            .navbar-custom {
                flex-wrap: wrap;
                justify-content: flex-end;
            }
        }
    </style>
</head>

<body>
    <header>
        <div class="container-fluid">

            <!-- Logo -->
            <span class="logo">To Do App</span>

            <!-- Search Bar -->
            <input
                type="text"
                id="search-bar"
                placeholder="🔍Search tasks..."
            />

            <!-- Navigation Links -->
            <div class="navbar-custom">
                <a class="nav-link" id="home" href="#">Home</a>
                <a class="nav-link" id="login" href="#">Login</a>
                <a class="nav-link" id="signup" href="#">Signup</a>
                <a class="nav-link" id="add-task" href="#">Add Task</a>
                <a class="nav-link" id="logout" href="#">Logout</a>
                <a class="nav-link" id="deactivate" href="#">Deactivate</a>
            </div>

        </div>
    </header>

    <main>
        <h1 style="font-size: 4vw; margin-left: 4%">
            Welcome <%- user ? user.username : "" %> 📝
        </h1>

        <p align="center">
            This is your To-Do List App.<br />
            Stay organized by adding and completing tasks!
        </p>
    </main>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const searchBar = document.getElementById("search-bar");
        const todocards = document.querySelectorAll(".todocard");

        if (searchBar) {
          searchBar.addEventListener("input", () => {
            let searchValue = searchBar.value.toLowerCase();
            todocards.forEach((card) => {
              const id = card.dataset.id.toLowerCase();
              const title = card.dataset.title.toLowerCase();
              const status = card.dataset.status.toLowerCase();
              const readableStatus = status === "true" ? "done" : "pending";
              if (
                id.includes(searchValue) ||
                title.includes(searchValue) ||
                readableStatus.includes(searchValue)
              ) {
                card.style.display = "flex";
              } else {
                card.style.display = "none";
              }
            });
          });
        }

        const postBtn = document.getElementById("add-task");
        const loginBtn = document.getElementById("login");
        const signupBtn = document.getElementById("signup");
        const logoutBtn = document.getElementById("logout");
        const homeBtn = document.getElementById("home");
        const deactivate = document.getElementById("deactivate");

        if (postBtn) postBtn.style.display = "none";
        if (deactivate) deactivate.style.display = "none";
        if (logoutBtn) logoutBtn.style.display = "none";

        if (postBtn)
          postBtn.onclick = () => (window.location.href = "/todo/post");
        if (homeBtn) homeBtn.onclick = () => window.location.replace("/todo");
        if (loginBtn)
          loginBtn.onclick = () => (window.location.href = "/loginPage");
        if (deactivate)
          deactivate.onclick = () => {
            window.location.replace("/account/deactivate/confirmation");
          };
        if (signupBtn)
          signupBtn.onclick = () => (window.location.href = "/signupPage");
        if (logoutBtn) {
          logoutBtn.onclick = () => {
            localStorage.removeItem("isLogged");
            localStorage.removeItem("userId");
            alert("Logged out");
            window.location.href = "/logout";
          };
        }

        function showButtons() {
          let isLogged = localStorage.getItem("isLogged");
          if (isLogged) {
            document.getElementById("search-bar").style.display = "block";
            if (loginBtn) loginBtn.style.display = "none";
            if (signupBtn) signupBtn.style.display = "none";
            if (postBtn) postBtn.style.display = "block";
            if (deactivate) deactivate.style.display = "block";
            if (logoutBtn) logoutBtn.style.display = "block";
          } else {
            if (loginBtn) loginBtn.style.display = "block";
            if (signupBtn) signupBtn.style.display = "block";
            if (postBtn) postBtn.style.display = "none";
            if (deactivate) deactivate.style.display = "none";
            if (logoutBtn) logoutBtn.style.display = "none";
          }
        }

        showButtons();
      });
    </script>
</body>
</html>