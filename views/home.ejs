<!DOCTYPE html>
<html>
  <head>
    <title>📝My Website</title>
    <style></style>
  </head>
  <body>
    <!-- Navbar -->
    <%- include("header",{user}) %>
    <div>
      <%todos.forEach(todo=>{%> <%-include('todocard',{todo:todo});%> <%})%>

      <script>
        document.addEventListener("DOMContentLoaded", () => {
          const deleteButtons = document.querySelectorAll(".del");
          deleteButtons.forEach((btn) => {
            btn.addEventListener("click", function () {
              let toDelete = this.parentElement.parentElement;
              let deleteId = toDelete.getAttribute("data-id");
              toDelete.remove();
              deleteTask(deleteId);
            });
          });

          const editButtons = document.querySelectorAll(".edit");
          editButtons.forEach((btn) => {
            btn.addEventListener("click", function () {
              let toEdit = this.parentElement.parentElement;
              let editId = toEdit.getAttribute("data-id");
              let editTitle = toEdit.getAttribute("data-title");
              editTask(editId, editTitle);
            });
          });
        });

        function editTask(editId, editTitle) {
          let id = editId;
          let title = editTitle;
          let url = `http://localhost:8080/todo/editform?id=${id}&title=${title}`;
          window.location.href = url;
        }

        function deleteTask(deleteId) {
          let xhr = new XMLHttpRequest();
          let url = "http://localhost:8080/delete";
          xhr.open("POST", url);
          xhr.onload = () => {
            let ackMsg = xhr.responseText || "";
            console.log(ackMsg.msg);
            if (ackMsg.msg === "fail") {
              alert("Id already exists");
            } else {
              window.location.replace("/todo");
            }
          };
          xhr.setRequestHeader("Content-Type", "application/json");
          xhr.send(JSON.stringify({ id: deleteId }));
        }
      </script>
    </div>
    <%- include("footer") %>
  </body>
</html>
